generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum ChampionshipStatus {
  OPEN
  IN_PROGRESS
  FINISHED
}

enum ChampionshipRole {
  OWNER
  ADMINISTRATOR
  ORGANIZER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum StageType {
  GROUP_STAGE
  KNOCKOUT
}

enum StageFormat {
  ROUND_ROBIN
  DOUBLE_ROUND_ROBIN
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum MatchEventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  MVP
}

enum BracketLinkOutcome {
  WINNER
  LOSER
}

enum BracketLinkSlot {
  HOME
  AWAY
}

enum AwardType {
  TOP_SCORER
  MATCH_MVP
  TOURNAMENT_MVP
  FAIR_PLAY
}

model User {
  id           String     @id
  name         String
  email        String     @unique
  passwordHash String?    @map("password_hash")
  googleId     String?    @unique @map("google_id")
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  ownedChampionships   Championship[]       @relation("ChampionshipOwner")
  championshipMembers  ChampionshipMember[]

  @@index([email])
  @@index([googleId])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id         String    @id
  userId     String    @map("user_id")
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id
  userId    String    @map("user_id")
  code      String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([code])
  @@map("password_reset_tokens")
}

model Championship {
  id          String             @id
  ownerUserId String             @map("owner_user_id")
  name        String
  slug        String             @unique
  description String?
  regulations String?
  startDate   DateTime           @map("start_date") @db.Date
  endDate     DateTime           @map("end_date") @db.Date
  status      ChampionshipStatus @default(OPEN)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  owner       User                 @relation("ChampionshipOwner", fields: [ownerUserId], references: [id])

  members     ChampionshipMember[]
  invitations Invitation[]
  teams       Team[]
  stages      Stage[]
  matches     Match[]
  standings   Standing[]
  awards      Award[]
  rules       ChampionshipRules?
  tieBreakerRules TieBreakerRule[]

  @@index([slug])
  @@index([ownerUserId])
  @@index([status])
  @@map("championships")
}

model ChampionshipMember {
  id             String           @id
  championshipId String           @map("championship_id")
  userId         String           @map("user_id")
  role           ChampionshipRole
  createdAt      DateTime         @default(now()) @map("created_at")

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([championshipId, userId])
  @@index([championshipId])
  @@index([userId])
  @@map("championship_members")
}

model Invitation {
  id             String           @id
  championshipId String           @map("championship_id")
  email          String
  role           ChampionshipRole
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime         @map("expires_at")
  acceptedAt     DateTime?        @map("accepted_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  @@index([championshipId])
  @@index([email])
  @@index([token])
  @@map("invitations")
}

model Team {
  id             String   @id
  championshipId String   @map("championship_id")
  name           String
  shortName      String?  @map("short_name")
  logoUrl        String?  @map("logo_url")
  primaryColor   String?  @map("primary_color")
  secondaryColor String?  @map("secondary_color")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  championship  Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  players       Player[]
  homeMatches   Match[]      @relation("HomeMatches")
  awayMatches   Match[]      @relation("AwayMatches")
  standings     Standing[]
  matchEvents   MatchEvent[]

  @@index([championshipId])
  @@index([name])
  @@map("teams")
}

model Player {
  id          String   @id
  teamId      String   @map("team_id")
  name        String
  shirtNumber Int?     @map("shirt_number")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  team        Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  statistics  PlayerStatistics?
  matchEvents MatchEvent[]
  awards      Award[]

  @@index([teamId])
  @@index([name])
  @@map("players")
}

model PlayerStatistics {
  id            String   @id
  playerId      String   @unique @map("player_id")
  matchesPlayed Int      @default(0) @map("matches_played")
  goals         Int      @default(0)
  assists       Int      @default(0)
  yellowCards   Int      @default(0) @map("yellow_cards")
  redCards      Int      @default(0) @map("red_cards")
  matchMvps     Int      @default(0) @map("match_mvps")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([goals])
  @@index([matchMvps])
  @@map("player_statistics")
}

model Stage {
  id               String      @id
  championshipId   String      @map("championship_id")
  name             String
  type             StageType
  format           StageFormat? @map("format")
  teamsToAdvance   Int         @default(1) @map("teams_to_advance")
  qualifiedTeams   Int?        @map("qualified_teams")
  thirdPlaceMatch  Boolean     @default(false) @map("third_place_match")
  displayOrder     Int         @map("display_order")
  createdAt        DateTime    @default(now()) @map("created_at")

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  groups       Group[]
  rounds       Round[]

  @@index([championshipId])
  @@index([displayOrder])
  @@map("stages")
}

model Group {
  id           String   @id
  stageId      String   @map("stage_id")
  name         String
  displayOrder Int      @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  stage    Stage     @relation(fields: [stageId], references: [id], onDelete: Cascade)
  matches  Match[]
  standings Standing[]

  @@index([stageId])
  @@index([displayOrder])
  @@map("groups")
}

model Round {
  id        String   @id
  stageId   String   @map("stage_id")
  number    Int
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  stage   Stage   @relation(fields: [stageId], references: [id], onDelete: Cascade)
  matches Match[]

  @@unique([stageId, number])
  @@index([stageId])
  @@map("rounds")
}

model Match {
  id             String      @id
  championshipId String      @map("championship_id")
  roundId        String      @map("round_id")
  groupId        String?     @map("group_id")
  homeTeamId     String?     @map("home_team_id")
  awayTeamId     String?     @map("away_team_id")
  scheduledAt    DateTime?   @map("scheduled_at")
  startedAt      DateTime?   @map("started_at")
  status         MatchStatus @default(SCHEDULED)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  championship    Championship     @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  round           Round            @relation(fields: [roundId], references: [id], onDelete: Cascade)
  group           Group?           @relation(fields: [groupId], references: [id])
  homeTeam        Team?            @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeam        Team?            @relation("AwayMatches", fields: [awayTeamId], references: [id])
  result          MatchResult?
  events          MatchEvent[]
  awards          Award[]
  bracketLinksFrom MatchBracketLink[] @relation("FromMatch")
  bracketLinksTo   MatchBracketLink[] @relation("ToMatch")

  @@index([championshipId])
  @@index([roundId])
  @@index([groupId])
  @@index([scheduledAt])
  @@map("matches")
}

model MatchResult {
  id               String   @id
  matchId          String   @unique @map("match_id")
  homeScore        Int      @map("home_score")
  awayScore        Int      @map("away_score")
  homePenaltyScore Int?     @map("home_penalty_score")
  awayPenaltyScore Int?     @map("away_penalty_score")
  createdAt        DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("match_results")
}

model MatchEvent {
  id        String         @id
  matchId   String         @map("match_id")
  playerId  String?        @map("player_id")
  teamId    String?        @map("team_id")
  eventType MatchEventType @map("event_type")
  minute    Int?
  notes     String?
  createdAt DateTime       @default(now()) @map("created_at")

  match  Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id])
  team   Team?   @relation(fields: [teamId], references: [id])

  @@index([matchId])
  @@index([playerId])
  @@index([eventType])
  @@map("match_events")
}

model MatchBracketLink {
  id          String             @id
  fromMatchId String             @map("from_match_id")
  toMatchId   String             @map("to_match_id")
  outcome     BracketLinkOutcome
  toSlot      BracketLinkSlot    @map("to_slot")
  createdAt   DateTime           @default(now()) @map("created_at")

  fromMatch Match @relation("FromMatch", fields: [fromMatchId], references: [id], onDelete: Cascade)
  toMatch   Match @relation("ToMatch", fields: [toMatchId], references: [id], onDelete: Cascade)

  @@unique([fromMatchId, outcome])
  @@map("match_bracket_links")
}

model Standing {
  id             String   @id
  championshipId String   @map("championship_id")
  stageId        String   @map("stage_id")
  groupId        String   @map("group_id")
  teamId         String   @map("team_id")
  position       Int      @default(0)
  points         Int      @default(0)
  wins           Int      @default(0)
  draws          Int      @default(0)
  losses         Int      @default(0)
  goalsScored    Int      @default(0) @map("goals_scored")
  goalsConceded  Int      @default(0) @map("goals_conceded")
  goalDifference Int      @default(0) @map("goal_difference")
  updatedAt      DateTime @updatedAt @map("updated_at")

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id])

  @@unique([stageId, groupId, teamId])
  @@index([championshipId])
  @@index([stageId])
  @@index([groupId])
  @@index([position])
  @@map("standings")
}

model ChampionshipRules {
  id                       String   @id
  championshipId           String   @unique @map("championship_id")
  winPoints                Int      @default(3) @map("win_points")
  drawPoints               Int      @default(1) @map("draw_points")
  penaltyBonusPoints       Int      @default(0) @map("penalty_bonus_points")
  yellowCardsForSuspension Int      @default(3) @map("yellow_cards_for_suspension")
  redCardSuspensionGames   Int      @default(1) @map("red_card_suspension_games")
  matchDuration            Int      @default(90) @map("match_duration")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  championship   Championship    @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  @@map("championship_rules")
}

model TieBreakerRule {
  id             String @id
  championshipId String @map("championship_id")
  position       Int
  criterion      String

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  @@unique([championshipId, position])
  @@index([championshipId])
  @@map("tie_breaker_rules")
}

model Award {
  id             String    @id
  championshipId String    @map("championship_id")
  playerId       String    @map("player_id")
  matchId        String?   @map("match_id")
  awardType      AwardType @map("award_type")
  createdAt      DateTime  @default(now()) @map("created_at")

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  player       Player       @relation(fields: [playerId], references: [id])
  match        Match?       @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([championshipId])
  @@index([playerId])
  @@index([matchId])
  @@map("awards")
}
